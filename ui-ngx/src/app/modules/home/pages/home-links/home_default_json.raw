          "showTitle": false,
          "backgroundColor": "rgb(255, 255, 255)",
          "color": "rgba(0, 0, 0, 0.87)",
          "padding": "8px",
          "settings": {
            "cardHtml": "<div class=\"topic\">\n    <div class=\"logo\">\n        <img class=\"logo\" src=\"data:image/png;base64,\" />\n    </div>\n    <div class=\"topicText\">\n        IoT Hub from Magenta Business\n    </div>\n</div>\n<br>\n<div class=\"infoText\">\n    IoT Hub is an IoT platform for data collection, processing, visualization, and device management -\n\n    that enables rapid development, management, and scaling of IoT projects.\n    <br>Our goal is to provide the out-of-the-box IoT solution that will enable server-side infrastructure for your IoT applications.\n</div>\n\n<br>\n<div class=\"infoText\">\n    Documentation, Quickstart Guides: <a href=\"someurl.magenta.at\">www.help.magent.at</a>\n    <br>\n    Support E-Mail: <a href=\"mailto:service4iot@magenta.at\">Service Team</a>\n</div>\n<br>\n<div class=\"infoText\">Application Access: <a target=\"_blank\" href=\"https://iothub.magenta.at/swagger-ui.html\">IoT Hub API Documentation</a></div>\n<br>\n<div class=\"infoText\">Device Access Information</div>\n<table class=\"infoText mainTable\">\n    <tr>\n        <td class=\"leftTable\">Direct Connected Devices</td>\n        <td>Public Connected Devices</td>\n    </tr>\n    <tr>\n        <td class=\"leftTable\">\n            <table>\n                <tr>\n                    <th>Network</th>\n                    <th>APN</th>\n                </tr>\n                <tr>\n                    <td>E/// DCP</td>\n                    <td>myiot.tma.iot</td>\n                </tr>\n                <tr>\n                    <td>DT WBC</td>\n                    <td>myiot.m2m.at</td>\n                </tr>\n            </table>\n        </td>\n        <td>\n            <table>\n                <tr>\n                    <th>Any access technology (public Internet, WIFI,LTE,5G,GPRS ..)</th>\n                </tr>\n            </table>\n        </td>\n    </tr>\n    <tr>\n        <td class=\"leftTable\"><br>Device Endpoints:</td>\n        <td ><br>Device Endpoints:</td>\n    </tr>\n    <tr>\n        <td  class=\"leftTable\">\n            <table class=\"detailTable\">\n                \n                <tr>\n                    <th>Protocol</th>\n                    <th>IP Addresses</th>\n                    <th>Ports</th>\n                </tr>\n                <tr>\n                    <td>LWM2M</td>\n                    <td>\n                        172.31.79.125<br>\n                        172.31.86.75<br>\n                        172.31.61.229<br>\n                        &nbsp;\n                    </td>\n                    <td>\n                        5685/UDP (no encryption)<br>\n                        5686/UDP (encryption)<br>\n                        5687/UDP (Bootstrap no encryption)<br>\n                        5688/UDP (Bootstrap encryption)\n                    </td>\n                </tr>\n                <tr>\n                    <td>CoAP</td>\n                    <td>\n                        172.31.78.49<br>\n                        172.31.83.246<br>\n                        172.31.60.74<br>\n                    </td>\n                    <td>\n                        5683/UDP (no encryption)<br>\n                        5684/UDP (encryption)<br>\n                    </td>\n                </tr>\n\n                <tr>\n                    <td>MQTT</td>\n                    <td>\n                        172.31.64.64<br>\n                        172.31.59.135<br>\n                        172.31.81.102<br>\n                    </td>\n                    <td>\n                        1883/TCP (no encryption)<br>\n                        8883/TCP (encryption MQTTS)<br>\n                    </td>\n                </tr>\n\n                <tr>\n                    <td>HTTP</td>\n                    <td>\n                        172.31.64.64<br>\n                        172.31.59.135<br>\n                        172.31.81.102<br>\n                    </td>\n                    <td>\n                        80/TCP (no encryption)<br>\n                        443/TCP (encryption HTTPS)<br>\n                    </td>\n                </tr>\n\n                <tr>\n                    <td>NTP</td>\n                    <td>\n                        172.31.25.113\n                    </td>\n                    <td>\n                        123/UDP\n                    </td>\n                </tr>\n\n            </table>\n        </td>\n        <td>\n            <table class=\"detailTable\">\n                <tr>\n                    <th>Protocol</th>\n                    <th>IP Addresses</th>\n                    <th>Ports</th>\n                </tr>\n                <tr>\n                    <td>LWM2M</td>\n                    <td>\n                        lwm2m.iothub.magenta.at<br>\n                        3.65.109.171<br>\n                        52.59.131.237<br>\n                        18.198.110.220<br>\n                        \n                    </td>\n                    <td>\n                        5686/UDP (encryption)<br>\n                        5688/UDP (Bootstrap encryption)\n                    </td>\n                </tr>\n                <tr>\n                    <td>CoAP</td>\n                    <td>\n                        coap-device.iothub.magenta.at<br>\n                        3.66.107.91<br>\n                        18.198.148.101<br>\n                        3.68.173.175<br>\n                    </td>\n                    <td>\n                        5684/UDP (encryption)<br>\n                    </td>\n                </tr>\n\n                <tr>\n                    <td>MQTT</td>\n                    <td>\n                        device.iothub.magenta.at<br>\n                        3.67.118.159<br>\n                        3.68.57.75<br>\n                        3.67.110.96<br>\n                    </td>\n                    <td>\n                        8883/TCP (encryption MQTTS)<br>\n                    </td>\n                </tr>\n\n                <tr>\n                    <td>HTTP</td>\n                    <td>\n                        device.iothub.magenta.at<br>\n                        3.67.118.159<br>\n                        3.68.57.75<br>\n                        3.67.110.96<br>\n                    </td>\n                    <td>\n                        443/TCP (encryption HTTPS)<br>\n                    </td>\n                </tr>\n\n                \n\n            </table>\n        </td>\n    </tr>\n\n</table>\n\n\n\n",
            "cardCss": ".card {\n    font-weight: bold;\n    font-size: 32px;\n    color: #999;\n    width: 100%;\n    height: 100%;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n}\n\n.topic {\n    display: flex;\n    align-items: center;\n    justify-content: center\n}\n\n.topicText {\n    color: #e20074;\n    font-family: \"TeleNeo Web,  Arial, Helvetica\", Sans-Serif;\n    font-size: 30pt;\n    padding-left: 20px;\n}\n\nimg {\n    max-width: 100%\n}\n\n.logo {\n\n    width: 100px;\n}\n\n.infoText {\n    font-family: \"TeleNeo Web,  Arial, Helvetica\", Sans-Serif;\n    font-size: 12pt;\n}\n\ntable {\n    width: 100%;\n    border-spacing: 0px;\n    border-collapse: separate;\n    xborder: 1px solid gray;\n\n}\n\nth {\n    text-align: left;\n}\n\ntd {\n    xborder: 1px solid gray;\n    padding: 5px;\n    vertical-align: top;\n}\n\n.mainTable {\n    border: 1px solid gray;\n}\n.leftTable {\n    border-right: 1px solid black;\n    width: 50%;\n}\n\ntable.detailTable tr:nth-child(even)  {\n            background-color: #EBEDEF;\n        }"
